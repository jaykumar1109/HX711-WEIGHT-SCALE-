// Add piezo status handler

void handleScan() {
  String json = "[";
  int n = WiFi.scanNetworks();
  for (int i = 0; i < n; ++i) {
    if (i) json += ",";
    json += "{";
    String ssid = WiFi.SSID(i);
    ssid.replace("\\", "\\\\"); // Escape backslashes for JSON
    ssid.replace("\"", "\\\""); // Escape quotes for JSON
    json += "\"ssid\":\"" + ssid + "\"";
    json += ",\"rssi\":" + String(WiFi.RSSI(i));
    json += ",\"encrypted\":" + String(WiFi.encryptionType(i) != WIFI_AUTH_OPEN);
    json += "}";
  }
  json += "]";
  server.send(200, "application/json", json);
}

void handleConnect() {
  String ssid = server.arg("ssid");
  String password = server.arg("password");
  memset(config.ssid, 0, sizeof(config.ssid));
  strncpy(config.ssid, ssid.c_str(), sizeof(config.ssid) - 1);
  
  memset(config.password, 0, sizeof(config.password));
  strncpy(config.password, password.c_str(), sizeof(config.password) - 1);
  config.configured = true;
  saveConfig();
  server.send(200, "text/plain", "WiFi credentials saved. Rebooting...");
  delay(1000);
  ESP.restart();
}

