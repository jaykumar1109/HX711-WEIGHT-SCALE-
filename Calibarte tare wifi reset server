  memset(config.gateway, 0, sizeof(config.gateway));
  strncpy(config.gateway, gateway.c_str(), sizeof(config.gateway) - 1);
  
  memset(config.mask, 0, sizeof(config.mask));
  strncpy(config.mask, mask.c_str(), sizeof(config.mask) - 1);
  
  memset(config.pdns, 0, sizeof(config.pdns));
  strncpy(config.pdns, pdns.c_str(), sizeof(config.pdns) - 1);
  
  memset(config.sdns, 0, sizeof(config.sdns));
  strncpy(config.sdns, sdns.c_str(), sizeof(config.sdns) - 1);
  saveConfig();
  
  server.send(200, "text/plain", "Network configuration saved. Reboot to apply changes.");
}

void handleApplyNetwork() {
  applyNetworkConfig();
  server.send(200, "text/plain", "Network configuration applied. Rebooting...");
  delay(1000);
  ESP.restart();
}

void handleNetworkStatus() {
  String json = "{";
  json += "\"host\":\"" + String(config.host) + "\"";
  json += ",\"ip\":\"" + (config.dhcp ? "" : String(config.ip)) + "\"";
  json += ",\"gateway\":\"" + (config.dhcp ? "" : String(config.gateway)) + "\"";
  json += ",\"mask\":\"" + (config.dhcp ? "" : String(config.mask)) + "\"";
  
  String dns = "";
  if (!config.dhcp) {
    dns = String(config.pdns);
    if (strlen(config.sdns) > 0) {
      dns += ", " + String(config.sdns);
    }
  }
  json += ",\"dns\":\"" + dns + "\"";
  json += "}";
  server.send(200, "application/json", json);
}

void handleGetConfig() {
  String json = "{";
  json += "\"serverIP\":\"" + String(config.serverIP) + "\"";
  json += ",\"serverPort\":" + String(config.serverPort);
  json += ",\"scaleID\":" + String(config.scaleID);
  json += ",\"host\":\"" + String(config.host) + "\"";
  json += ",\"dhcp\":" + String(config.dhcp);
  json += ",\"ip\":\"" + String(config.ip) + "\"";
  json += ",\"gateway\":\"" + String(config.gateway) + "\"";
  json += ",\"mask\":\"" + String(config.mask) + "\"";
  json += ",\"pdns\":\"" + String(config.pdns) + "\"";
  json += ",\"sdns\":\"" + String(config.sdns) + "\"";
  json += "}";
  server.send(200, "application/json", json);
}

void handleResetCounter() {
  String type = server.arg("type");
  
  if (type == "readings") counters.totalReadings = 0;
  else if (type == "success") counters.successfulTransmissions = 0;
  else if (type == "failed") counters.failedTransmissions = 0;
  else if (type == "stats") {
    counters.maxWeight = 0;
    counters.minWeight = 0;
    counters.totalWeight = 0;
  }
  
  saveCounters();
  server.send(200, "text/plain", "Counter reset: " + type);
}

void handleStatus() {
  String status;
  if (WiFi.status() == WL_CONNECTED) {
    status = "Connected - " + WiFi.localIP().toString();
  } else if (WiFi.getMode() == WIFI_AP) {
    status = "AP Mode - " + WiFi.softAPIP().toString();
  } else {
    status = "Disconnected";
  }
  server.send(200, "text/plain", status);
}

void handleScaleStatus() {
  server.send(200, "text/plain", scaleStatus);
}

void handleResetWiFi() {
  config.configured = false;
  saveConfig();
  server.send(200, "text/plain", "WiFi configuration reset. Rebooting...");
  delay(1000);
  ESP.restart();
}

void handleFactoryReset() {
  for (int i = 0; i < sizeof(config) + sizeof(counters); i++) {
    EEPROM.write(i, 0);
  }
  EEPROM.commit();
  
  server.send(200, "text/plain", "Factory reset complete. Rebooting...");
  delay(1000);
  ESP.restart();
}

void setupWebServer() {
  server.on("/", HTTP_GET, handleRoot);
  server.on("/scan", HTTP_GET, handleScan);
  server.on("/connect", HTTP_POST, handleConnect);
  server.on("/overview", HTTP_GET, handleOverview);
  server.on("/calibrationstatus", HTTP_GET, handleCalibrationStatus);
  server.on("/currentweight", HTTP_GET, handleCurrentWeight);
  server.on("/tare", HTTP_POST, handleTare);
  server.on("/calibrate", HTTP_POST, handleCalibrate);
  server.on("/resetcalibration", HTTP_POST, handleResetCalibration);
  server.on("/sendweight", HTTP_POST, handleSendWeight);
  server.on("/getreadings", HTTP_GET, handleGetReadings);
  server.on("/addmanualreading", HTTP_POST, handleAddManualReading);
  server.on("/clearreadings", HTTP_GET, handleClearReadings);
  server.on("/saveconfig", HTTP_POST, handleSaveConfig);
  server.on("/savescalesettings", HTTP_POST, handleSaveScaleSettings);
  server.on("/savenetwork", HTTP_POST, handleSaveNetwork);
  server.on("/applynetwork", HTTP_GET, handleApplyNetwork);
  server.on("/networkstatus", HTTP_GET, handleNetworkStatus);
  server.on("/getconfig", HTTP_GET, handleGetConfig);
  server.on("/resetcounter", HTTP_POST, handleResetCounter);
  server.on("/status", HTTP_GET, handleStatus);
  server.on("/scalestatus", HTTP_GET, handleScaleStatus);
  server.on("/resetwifi", HTTP_GET, handleResetWiFi);
  server.on("/factoryreset", HTTP_GET, handleFactoryReset);

  server.begin();
  Serial.println("HTTP server started on port 80");
  Serial.println("Access point: ESP32-SCALE");
  Serial.println("Password: password");
  Serial.println("Default IP: http://" + (WiFi.status() == WL_CONNECTED ? WiFi.localIP().toString() : WiFi.softAPIP().toString()));
}
