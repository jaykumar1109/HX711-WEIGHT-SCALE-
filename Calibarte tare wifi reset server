WebServer server(80);

// HX711 scale setup
HX711 scale;
const int LOADCELL_DOUT_PIN = 18;  // GPIO18
const int LOADCELL_SCK_PIN = 19;   // GPIO19

// LED setup (optional status indicators)
const int ledPin1 = 2;      // First LED pin
const int ledPin2 = 3;      // Second LED pin
bool weightReadingInProgress = true;

// EEPROM structure
struct Config {
  char ssid[33];
  char password[65];
  bool configured;
  char serverIP[32];
  int serverPort;
  int scaleID;
  char host[16];
  bool dhcp;
  char ip[16];
  char gateway[16];
  char mask[16];
  char pdns[16];
  char sdns[16];
  float calibrationFactor;
  float knownWeight;
};

Config config;

// Weight counters
struct WeightCounters {
  uint32_t totalReadings;
  uint32_t successfulTransmissions;
  uint32_t failedTransmissions;
  float maxWeight;
  float minWeight;
  float totalWeight;
};

WeightCounters counters;

String serialBuffer = "";

// Weight reading storage
struct WeightReading {
  float weight;
  String timestamp;
  String unit;
};

const int MAX_READINGS = 50;
WeightReading weightList[MAX_READINGS];
int readingCount = 0;

// Scale status
String scaleStatus = "Not Calibrated";
String urlStatus = "Disconnected";
String lastTareResponse = "";
String currentUnit = "g";

// Scale variables
bool isTaring = false;
unsigned long lastStableReading = 0;
float lastStableWeight = 0;
bool weightStable = false;

void setup() {
  Serial.begin(115200);
  
  // Initialize EEPROM for ESP32
  EEPROM.begin(sizeof(config) + sizeof(counters));
  
  Serial.println("\n=== ESP32 Smart Weight Scale ===");
  
  // Initialize LEDs
  pinMode(ledPin1, OUTPUT);
  pinMode(ledPin2, OUTPUT);
  digitalWrite(ledPin1, LOW);
  digitalWrite(ledPin2, LOW);
  
  // Initialize HX711
  initializeScale();
  
  // Load configuration from EEPROM
  loadConfig();
  
  // Apply network configuration
  applyNetworkConfig();
  
  if (config.configured) {
    connectToWiFi();
  } else {
    startAPMode();
  }
  
  setupWebServer();
  loadCounters();
  
  Serial.println("=== System Ready ===");
  Serial.println("Ready for weight measurements...\n");
}

void loop() {
  server.handleClient();
  
  // Handle weight readings
  handleScaleReadings();
  
  // Handle serial input
  if (Serial.available()) {
    String data = Serial.readString();
    serialBuffer += data;
    
    // Keep buffer size manageable
    if (serialBuffer.length() > 4000) {
      serialBuffer = serialBuffer.substring(serialBuffer.length() - 3000);
    }
  }
  
  // Periodically check scale status
  static unsigned long lastStatusCheck = 0;
  if (millis() - lastStatusCheck > 30000) {
    checkScaleStatus();
    lastStatusCheck = millis();
  }
}

void turnOnLEDs() {
  digitalWrite(ledPin1, HIGH);
  digitalWrite(ledPin2, HIGH);
}
 
void turnOffLEDs() {
  digitalWrite(ledPin1, LOW);
  digitalWrite(ledPin2, LOW);
}

void initializeScale() {
  scale.begin(LOADCELL_DOUT_PIN, LOADCELL_SCK_PIN);
  delay(2000);

  if (scale.is_ready()) {
    Serial.println("âœ“ HX711 found and ready!");
    
    // Set scale calibration factor
    // Set scale calibration factor (allow negative, but not zero)
    scale.set_scale(abs(config.calibrationFactor) > 0.00001 ? config.calibrationFactor : 25.21);
    
    // Reset the scale to 0
    Serial.println("Taring scale... Remove any weight from scale.");
    scale.tare();
    Serial.println("Tare complete.");
    
    if (config.calibrationFactor <= 0) {
      Serial.println("\n=== Reading Scale Values ===");
      Serial.println("Place known weight on scale for calibration");
      Serial.println("=====================================");
    }
  } else {
    Serial.println("âœ— HX711 not found!");
    
    while(1) {
      delay(1000);
      Serial.println("HX711 not detected - Check wiring and restart");
    }
  }
}

void handleScaleReadings() {
  static unsigned long lastReadingTime = 0;
  
  // Take readings every 500ms
  if (millis() - lastReadingTime > 500) {
    if (scale.is_ready()) {
      float weight = scale.get_units(1);
      
      // Update statistics
      updateWeightStatistics(weight);
      
      // Check if weight is stable
      checkWeightStability(weight);
      
      // Store reading if it's stable and different from last stable reading
      if (weightStable && abs(weight - lastStableWeight) > 0.1) {
        storeWeightReading(weight);
        lastStableWeight = weight;
        
        // Auto-send to server if configured and connected
        if (WiFi.status() == WL_CONNECTED && strlen(config.serverIP) > 0) {
          forwardWeightToServer(weight);
        }
        
        Serial.println("=== WEIGHT READING STORED ===");
        Serial.println("Weight: " + String(weight, 2) + currentUnit);
      } else if (weightStable) {
        // Weight is stable but hasn't changed much
        Serial.println("Current weight: " + String(weight, 2) + currentUnit + " (stable)");
      } else {
        // Weight not stable yet
        Serial.println("Current weight: " + String(weight, 2) + currentUnit + " (unstable)");
      }
    } else {
      Serial.println("[SCALE] HX711 not found, check wiring");
    }
    
    lastReadingTime = millis();
  }
}

void checkWeightStability(float currentWeight) {
  static float previousWeights[5] = {0};
  static int weightIndex = 0;
  static unsigned long lastWeightTime = 0;
  
  // Store current weight in circular buffer
  previousWeights[weightIndex] = currentWeight;
  weightIndex = (weightIndex + 1) % 5;
  
  // Check stability every 500ms
  if (millis() - lastWeightTime > 500) {
    float avg = 0;
    float variance = 0;
    
    // Calculate average
    for (int i = 0; i < 5; i++) {
      avg += previousWeights[i];
    }
    avg /= 5;
    
    // Calculate variance
    for (int i = 0; i < 5; i++) {
      variance += pow(previousWeights[i] - avg, 2);
    }
    variance /= 5;
    
    // Weight is stable if variance is low
    weightStable = (variance < 0.5);
    
    if (weightStable) {
      lastStableReading = millis();
    }
    
    lastWeightTime = millis();
  }
}

void updateWeightStatistics(float weight) {
  counters.totalReadings++;
  counters.totalWeight += weight;
  
  if (weight > counters.maxWeight) {
    counters.maxWeight = weight;
  }
  
  if (weight < counters.minWeight || counters.minWeight == 0) {
    counters.minWeight = weight;
  }
  
  // Save counters periodically
  static unsigned long lastSave = 0;
  if (millis() - lastSave > 60000) {
    saveCounters();
    lastSave = millis();
  }
}

void storeWeightReading(float weight) {
  String timestamp = getDateTime();
  
  if (readingCount < MAX_READINGS) {
    weightList[readingCount].weight = weight;
    weightList[readingCount].timestamp = timestamp;
    weightList[readingCount].unit = currentUnit;
    readingCount++;
  } else {
    // Shift array to make space
    for (int i = 0; i < MAX_READINGS - 1; i++) {
      weightList[i] = weightList[i + 1];
    }
    weightList[MAX_READINGS - 1].weight = weight;
    weightList[MAX_READINGS - 1].timestamp = timestamp;
    weightList[MAX_READINGS - 1].unit = currentUnit;
  }
  
  Serial.println("[SCALE] Stored reading: " + String(weight, 2) + currentUnit + " at " + timestamp);
}

void applyNetworkConfig() {
  if (strlen(config.host) > 0) {
    WiFi.setHostname(config.host);
  }
  
  if (!config.dhcp && strlen(config.ip) > 0) {
    IPAddress ip, gateway, mask, pdns, sdns;
    
    if (ip.fromString(config.ip) && 
        gateway.fromString(config.gateway) && 
        mask.fromString(config.mask)) {
      
      if (pdns.fromString(config.pdns)) {
        if (sdns.fromString(config.sdns)) {
          WiFi.config(ip, gateway, mask, pdns, sdns);
        } else {
          WiFi.config(ip, gateway, mask, pdns);
        }
      } else {
        WiFi.config(ip, gateway, mask);
      }
      Serial.println("[NETWORK] Static IP configuration applied");
    }
  } else {
    Serial.println("[NETWORK] DHCP configuration");
  }
}

void loadConfig() {
  EEPROM.get(0, config);
  if (!config.configured) {
    memset(&config, 0, sizeof(config));
    strcpy(config.serverIP, "192.168.1.134");
    config.serverPort = 80;
    config.scaleID = 200;
    strcpy(config.host, "ESP32-Scale");
    config.dhcp = true;
    strcpy(config.ip, "192.168.1.69");
    strcpy(config.gateway, "192.168.1.1");
    strcpy(config.mask, "255.255.255.0");
    strcpy(config.pdns, "8.8.8.8");
    strcpy(config.sdns, "8.8.4.4");
    config.calibrationFactor = 1.0;
    config.knownWeight = 100.0;
    config.configured = false;
  }
}

void saveConfig() {
  EEPROM.put(0, config);
  EEPROM.commit();
  Serial.println("[CONFIG] Configuration saved to EEPROM");
}

void loadCounters() {
  EEPROM.get(sizeof(config), counters);
  if (counters.totalReadings > 1000000) counters.totalReadings = 0;
  if (counters.successfulTransmissions > 1000000) counters.successfulTransmissions = 0;
  if (counters.failedTransmissions > 1000000) counters.failedTransmissions = 0;
}

void saveCounters() {
  EEPROM.put(sizeof(config), counters);
  EEPROM.commit();
}

void connectToWiFi() {
  WiFi.mode(WIFI_STA);
  applyNetworkConfig();
  WiFi.begin(config.ssid, config.password);
  
  Serial.print("[WiFi] Connecting to ");
  Serial.println(config.ssid);
  
  int attempts = 0;
  while (WiFi.status() != WL_CONNECTED && attempts < 30) {
    delay(500);
    Serial.print(".");
    attempts++;
  }
  
  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("\n[WiFi] Connected! IP: " + WiFi.localIP().toString());
    urlStatus = "Connected";
  } else {
    Serial.println("\n[WiFi] Failed to connect");
    startAPMode();
  }
}

void startAPMode() {
  WiFi.mode(WIFI_AP);
  WiFi.softAP("ESP32-SCALE", "password");
  Serial.println("[WiFi] AP Mode Started: ESP32-SCALE");
  Serial.println("IP: " + WiFi.softAPIP().toString());
  urlStatus = "AP Mode";
}

bool forwardWeightToServer(float weight) {
  if (WiFi.status() != WL_CONNECTED) {
    Serial.println("[SERVER] ERROR: Cannot forward - WiFi disconnected");
    return false;
  }

  WiFiClient client;
  
  String url = "/?scaleid=" + String(config.scaleID);
  url += "&weight_type=W";
  url += "&weight_value=" + String(weight, 2);
  url += "&unit=" + currentUnit;
  url += "&date=" + getDateTime();
  
  Serial.println("[SERVER] Forwarding to: http://" + String(config.serverIP) + ":" + String(config.serverPort) + url);
  
  if (client.connect(config.serverIP, config.serverPort)) {
    client.println("GET " + url + " HTTP/1.1");
    client.println("Host: " + String(config.serverIP) + ":" + String(config.serverPort));
    client.println("User-Agent: ESP32-WeightScale/1.0");
    client.println("Connection: close");
    client.println();
    
    unsigned long timeout = millis();
    while (client.available() == 0) {
      if (millis() - timeout > 10000) {
        Serial.println("[SERVER] ERROR: Client Timeout!");
        client.stop();
        counters.failedTransmissions++;
        saveCounters();
        return false;
      }
      delay(10);
    }
    
    String statusLine = client.readStringUntil('\n');
    Serial.println("[SERVER] Response: " + statusLine);
    
    while (client.available()) {
      String line = client.readStringUntil('\n');
      if (line == "\r") {
        break;
      }
    }
    
    String responseBody = "";
    while (client.available()) {
      responseBody += client.readString();
    }
    
    client.stop();
    
    if (statusLine.indexOf("200") > 0) {
      Serial.println("[SERVER] SUCCESS: HTTP 200 OK");
      counters.successfulTransmissions++;
      saveCounters();
      return true;
    } else if (statusLine.indexOf("201") > 0) {
      Serial.println("[SERVER] SUCCESS: HTTP 201 Created");
      counters.successfulTransmissions++;
      saveCounters();
      return true;
    } else {
      Serial.println("[SERVER] ERROR: HTTP Status: " + statusLine);
      Serial.println("[SERVER] Response Body: " + responseBody);
      counters.failedTransmissions++;
      saveCounters();
      return false;
    }
  } else {
    Serial.println("[SERVER] ERROR: Connection failed to " + String(config.serverIP) + ":" + String(config.serverPort));
    counters.failedTransmissions++;
    saveCounters();
    return false;
  }
}

String getDateTime() {
  unsigned long seconds = millis() / 1000;
  unsigned long minutes = seconds / 60;
  unsigned long hours = minutes / 60;
  unsigned long days = hours / 24;
  
  hours = hours % 24;
  minutes = minutes % 60;
  seconds = seconds % 60;
  
  char buffer[20];
  snprintf(buffer, sizeof(buffer), "%02lu/%02lu/%04lu,%02lu:%02lu:%02lu", 
           1, 1, 2024, hours, minutes, seconds);
  return String(buffer);
}

void checkScaleStatus() {
  if (scale.is_ready()) {
    if (config.calibrationFactor > 0) {
      scaleStatus = "Calibrated";
    } else {
      scaleStatus = "Ready (Needs Calibration)";
    }
  } else {
    scaleStatus = "Hardware Error";
  }
}

// ============================ CALIBRATION FUNCTIONS ============================

bool calibrateScale(float knownWeight) {
  Serial.println("[CALIBRATION] Step 2: Measuring known weight (" + String(knownWeight) + "g)...");
  
  if (!scale.is_ready()) {
    Serial.println("[CALIBRATION] ERROR: HX711 not found.");
    return false;
  }

  scale.set_scale(1.0); // Reset scale to raw mode
  float reading = scale.get_units(10);
  
  Serial.print("[CALIBRATION] Raw Reading: ");
  Serial.println(reading);

  // Validation: If the raw delta is too small, something is wrong
  if (abs(reading) < 50) {
    Serial.println("[CALIBRATION] ERROR: Reading too small! Did you place the weight?");
    return false;
  }

  float calibrationFactor = reading / knownWeight;
  config.calibrationFactor = calibrationFactor;
  config.knownWeight = knownWeight;
  scale.set_scale(calibrationFactor);
  
  Serial.println("[CALIBRATION] SUCCESS!");
  Serial.println("[CALIBRATION] New Factor: " + String(calibrationFactor, 6));
  
  saveConfig();
  scaleStatus = "Calibrated";
  return true;
}

bool tareScale() {
  if (!scale.is_ready()) {
    Serial.println("[TARE] ERROR: Scale not ready");
    return false;
  }
  
  Serial.println("[TARE] Taring scale... Please ensure no weight on scale");
  
  unsigned long startTime = millis();
  float currentReading = 0;
  int stableCount = 0;
  
  while (millis() - startTime < 15000) {
    if (scale.is_ready()) {
      float newReading = scale.get_units(1);
      
      if (abs(newReading - currentReading) < 50) {
        stableCount++;
      } else {
        stableCount = 0;
        currentReading = newReading;
      }
      
      if (stableCount > 5) {
        scale.tare();
        Serial.println("[TARE] SUCCESS: Scale tared");
        lastTareResponse = "TARE SUCCESS - Scale zeroed";
        return true;
      }
    }
    delay(500);
  }
  
  Serial.println("[TARE] ERROR: Timeout - could not get stable zero reading");
  lastTareResponse = "TARE FAIL - Could not zero scale";
  return false;
}

