void loop() {
// Update weight reading continuously
updateWeight();

// Update LCD display
lcd.setCursor(0, 0);
lcd.print("W:" + String(currentWeight, 1) + "g  ");

lcd.setCursor(0, 1);
if (WiFi.status() == WL_CONNECTED) {
lcd.print(WiFi.localIP());
lcd.print(" ");
} else {
lcd.print("No WiFi");
}

// Handle web requests
server.handleClient();

delay(200); // Fast update for live reading
}

