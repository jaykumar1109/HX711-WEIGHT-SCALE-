// ========== Pins ==========
HX711 scale;
uint8_t dataPin = 4;
uint8_t clockPin = 18;

// LCD pins
const int rs = 13, en = 12, d4 = 14, d5 = 5, d6 = 22, d7 = 23;
LiquidCrystal lcd(rs, en, d4, d5, d6, d7);

// ========== WiFi ==========
const char* ssid = "BMTECHNO";
const char* password = "22102001";

// ========== EEPROM Addresses ==========
#define EEPROM_SIZE 512
#define ADDR_OFFSET 0
#define ADDR_SCALE_FACTOR 4

// ========== Calibration Variables ==========
long calibrationOffset = 0;
float calibrationScaleFactor = 1.0;
bool isCalibrated = false;

// ========== Other Variables ==========
const int AVG_SAMPLES = 10;
float currentWeight = 0;
float rawReading = 0;

WebServer server(80);

// ========== Load calibration from EEPROM ==========
void loadCalibration() {
EEPROM.begin(EEPROM_SIZE);

// Read offset (4 bytes)
EEPROM.get(ADDR_OFFSET, calibrationOffset);

// Read scale factor (4 bytes)
EEPROM.get(ADDR_SCALE_FACTOR, calibrationScaleFactor);

// Check if values are valid
if (calibrationOffset == 0xFFFFFFFF || calibrationOffset == 0) {
Serial.println("No calibration found, using defaults");
calibrationOffset = 0;
calibrationScaleFactor = 1.0;
isCalibrated = false;
} else {
Serial.println("Calibration loaded from EEPROM");
Serial.print("Offset: ");
Serial.println(calibrationOffset);
Serial.print("Scale Factor: ");
Serial.println(calibrationScaleFactor, 6);
isCalibrated = true;
}

EEPROM.end();
}

// ========== Save calibration to EEPROM ==========
void saveCalibration() {
EEPROM.begin(EEPROM_SIZE);

EEPROM.put(ADDR_OFFSET, calibrationOffset);
EEPROM.put(ADDR_SCALE_FACTOR, calibrationScaleFactor);

EEPROM.commit();
EEPROM.end();

Serial.println("Calibration saved to EEPROM");
Serial.print("Offset: ");
Serial.println(calibrationOffset);
Serial.print("Scale Factor: ");
Serial.println(calibrationScaleFactor, 6);
}

// ========== Apply calibration to scale ==========
void applyCalibration() {
scale.set_offset(calibrationOffset);
scale.set_scale(calibrationScaleFactor);
Serial.println("Calibration applied to scale");

// Force a reading to verify calibration
delay(100);
float testWeight = scale.get_units(5);
Serial.print("Verification reading: ");
Serial.print(testWeight, 1);
Serial.println(" grams");
}

// ========== Tare (zero the scale) ==========
void tareScale() {
Serial.println("Taring scale...");
scale.tare(20);
// Update offset after tare
calibrationOffset = scale.get_offset();
saveCalibration(); // Save the new offset
Serial.println("Scale tared and saved!");
}

// ========== Update live weight ==========
void updateWeight() {
rawReading = scale.get_units(AVG_SAMPLES);
currentWeight = (rawReading < 0) ? 0 : rawReading;
}

void setup() {
Serial.begin(115200);

// Initialize LCD
lcd.begin(16, 2);
lcd.clear();
lcd.print("Starting...");

// Initialize HX711
scale.begin(dataPin, clockPin);

// Load saved calibration
loadCalibration();

if (isCalibrated) {
applyCalibration();
} else {
scale.set_offset(0);
scale.set_scale(1.0);
}

// Auto tare
lcd.setCursor(0, 1);
lcd.print("Taring...");
delay(500);
tareScale();

// Connect to WiFi
lcd.clear();
lcd.print("Connecting WiFi");
WiFi.begin(ssid, password);

int attempts = 0;
while (WiFi.status() != WL_CONNECTED && attempts < 20) {
delay(500);
attempts++;
Serial.print(".");
}

lcd.clear();

if (WiFi.status() == WL_CONNECTED) {
lcd.setCursor(0, 0);
lcd.print("IP:");
lcd.print(WiFi.localIP());
lcd.setCursor(0, 1);
lcd.print("Ready!");

